{
  "name": "Bowow",
  "version": "1.0.0",
  "private": true,
  "description": "Bowow - AI coding agent",
  "author": "yasser-27",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:win": "vite build && electron-builder --win --config",
    "build:mac": "vite build && electron-builder --mac --config",
    "build:linux": "vite build && electron-builder --linux --config",
    "postinstall": "echo skipping"
  },
  "build": {
    "appId": "com.yasser.build-agent",
    "productName": "Bowow",
    "directories": {
      "output": "release"
    },
    "afterPack": "build/afterPack.js",
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"]
    },
    "linux": {
      "target": ["AppImage"]
    }
  },
  "dependencies": {
    "diff": "^9.0.0",
    "jszip": "^3.10.1",
    "partial-json": "^0.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.6.1",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/diff": "^6.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "rcedit": "^4.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0"
  }
}
